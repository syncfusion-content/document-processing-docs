<ejs-spreadsheet id="spreadsheet" actionBegin="actionBegin">
    <e-spreadsheet-sheets>
        <e-spreadsheet-sheet name="Sheet1">
            <e-spreadsheet-ranges>
                <e-spreadsheet-range dataSource="ViewBag.CustomerData" startCell="A1"></e-spreadsheet-range>
            </e-spreadsheet-ranges>
        </e-spreadsheet-sheet>
    </e-spreadsheet-sheets>
</ejs-spreadsheet>

<script>
    var spreadsheet;

    function actionBegin(args) {
        var action = args.action;
        var eventArgs = args.args ? args.args.eventArgs : args.eventArgs;

        // Check the action is beforeReplaceAll.
        if (action === 'beforeReplaceAll') {
            var spreadsheetElement = document.getElementById('spreadsheet');
            if (spreadsheetElement && spreadsheetElement.ej2_instances) {
                spreadsheet = spreadsheetElement.ej2_instances[0];
            }
            if (!spreadsheet) return;

            // Get the active sheet's selected range.
            var selectedRange = spreadsheet.getActiveSheet().selectedRange;
            if (!selectedRange) return;

            // Convert the selected range into cell collection.
            var selectedRangeCollection = generateCellCollection(selectedRange, spreadsheet);
            var replaceAllCollection = eventArgs.addressCollection;
            if (!Array.isArray(replaceAllCollection)) return;

            // Create a Set from selectedRangeCollection for efficient lookup.
            var selectedSet = new Set(selectedRangeCollection);
            var updatedCollection = [];

            // Iterate through replaceAllCollection and keep only cells within selection.
            for (var i = 0; i < replaceAllCollection.length; i++) {
                var cell = replaceAllCollection[i];
                if (cell && selectedSet.has(cell)) {
                    updatedCollection.push(cell);
                } else {
                    // If the cell is not in selectedRangeCollection, add null to the updated collection
                    updatedCollection.push(null);
                }
            }

            if (updatedCollection.length > 0) {
                // Assign the newly created cell collection to the addressCollection of replaceAll action.
                eventArgs.addressCollection = updatedCollection;
            }
        }
    }

    function generateCellCollection(range, spreadsheet) {
        // Initialize the collection that will hold cell references.
        var collection = [];

        // Split the range string into start and end cell references.
        var rangeParts = range.split(':');
        var startCell = rangeParts[0];
        var endCell = rangeParts[1] || startCell;

        // Get the name of the active sheet.
        var activeSheetName = spreadsheet.getActiveSheet().name;

        // Extract column and row numbers from start and end cell references.
        var startMatch = startCell.match(/[A-Z]+|\d+/g) || [];
        var endMatch = endCell.match(/[A-Z]+|\d+/g) || [];

        var startCol = startMatch[0];
        var startRow = startMatch[1];
        var endCol = endMatch[0];
        var endRow = endMatch[1];

        // Calculate ASCII codes for start and end columns.
        var colStart = startCol.toUpperCase().charCodeAt(0);
        var colEnd = endCol.toUpperCase().charCodeAt(0);

        // Parse start and end row numbers.
        var rowStart = parseInt(startRow, 10);
        var rowEnd = parseInt(endRow, 10);

        // Iterate over columns and rows within the specified range.
        for (var col = colStart; col <= colEnd; col++) {
            for (var row = rowStart; row <= rowEnd; row++) {
                // Push each cell reference into the collection array
                collection.push(activeSheetName + '!' + String.fromCharCode(col) + row);
            }
        }

        // Return the array of cell references.
        return collection;
    }
</script>
