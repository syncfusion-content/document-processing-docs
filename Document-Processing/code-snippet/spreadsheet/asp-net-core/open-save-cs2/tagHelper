<ejs-spreadsheet id="spreadsheet" openUrl="Open" allowOpen="true" saveUrl="Save" allowSave="true" created="handleCreated"></ejs-spreadsheet>

<script>
    function handleCreated() {
        // Get the Spreadsheet instance
        var spreadsheet = document.getElementById('spreadsheet').ej2_instances[0];
        if (spreadsheet) {
            // Fetch the remote Excel file from the specified URL
            const fetchData = async () => {
                try {
                    // fetch the remote url
                    const response = await fetch('https://cdn.syncfusion.com/scripts/spreadsheet/Sample.xlsx');
                    // convert the excel file to blob
                    const fileBlob = await response.blob();
                    // convert the blob into file
                    const file = new File([fileBlob], 'Sample.xlsx');
                    // open the file into Spreadsheet
                    spreadsheet.open({ file });
                } catch (error) {
                    console.error('Error loading file:', error);
                }
            };
            fetchData();
        }
    }
</script>
